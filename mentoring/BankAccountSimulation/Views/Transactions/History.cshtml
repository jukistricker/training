@model IEnumerable<BankAccountSimulation.Models.Transaction>

@{
    ViewData["Title"] = "Transaction History";
    string accNo = ViewBag.AccountNumber;
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int totalCount = ViewBag.TotalCount;
    string currentType = ViewBag.CurrentType ?? "All";
}

<div class="container-fluid">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-body border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-primary">
                <i class="bi bi-clock-history me-2"></i>History: @accNo
                <span class="badge bg-secondary ms-2 fw-normal fs-6">@totalCount transactions</span>
            </h5>
            <div class="btn-group btn-group-sm">
                <a asp-action="History" asp-route-type="All" asp-route-page="1"
                   class="btn btn-outline-secondary @(currentType == "All" ? "active" : "")">All</a>
                <a asp-action="History" asp-route-type="Deposit" asp-route-page="1"
                   class="btn btn-outline-secondary @(currentType == "Deposit" ? "active" : "")">Deposit</a>
                <a asp-action="History" asp-route-type="Withdraw" asp-route-page="1"
                   class="btn btn-outline-secondary @(currentType == "Withdraw" ? "active" : "")">Withdraw</a>
                <a asp-action="History" asp-route-type="Transfer" asp-route-page="1"
                   class="btn btn-outline-secondary @(currentType == "Transfer" ? "active" : "")">Transfer</a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="border-bottom">
                    <tr>
                        <th class="ps-4">Time</th>
                        <th>Transaction type</th>
                        <th>Amount</th>
                        <th>Description</th>
                        <th class="text-end pe-4">Transaction ID</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                No transactions have been made yet.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var tr in Model)
                        {
                            string colorClass = "";
                            string iconClass = "";
                            string prefix = "";
                            string badgeClass = "";

                            switch (tr.Type)
                            {
                                case TransactionType.Deposit:
                                    colorClass = "text-success";
                                    badgeClass = "bg-success-subtle text-success";
                                    iconClass = "bi-arrow-down-left";
                                    prefix = "+";
                                    break;
                                case TransactionType.Withdraw:
                                    colorClass = "text-danger";
                                    badgeClass = "bg-danger-subtle text-danger";
                                    iconClass = "bi-arrow-up-right";
                                    prefix = "-";
                                    break;
                                case TransactionType.Transfer:
                                    colorClass = "text-warning"; 
                                    badgeClass = "bg-primary-subtle text-primary border-primary"; 
                                    iconClass = "bi-arrow-left-right";
                                    prefix = ""; 
                                    break;
                            }

                            <tr>
                                <td class="ps-4">
                                    <div class="small fw-bold">@tr.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted small">@tr.CreatedAt.ToString("HH:mm:ss")</div>
                                </td>
                                <td>
                                    <span class="badge @badgeClass border px-2 py-1">
                                        <i class="bi @iconClass me-1"></i>
                                        @tr.Type
                                    </span>
                                </td>
                                <td class="fw-bold fs-6">
                                    <span class="@colorClass">
                                        @prefix @tr.Amount.ToString("N0") <small>₫</small>
                                    </span>
                                </td>
                                <td class="text-muted small">@tr.Description</td>
                                <td class="text-end pe-4 text-uppercase small text-muted">#@tr.Id</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-body py-3 d-flex justify-content-between align-items-center">
            <a asp-controller="Accounts" asp-action="Details" class="btn btn-link text-muted text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Return
            </a>

            @if (totalPages > 1)
            {
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small">Page @currentPage of @totalPages</span>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="History"
                                   asp-route-type="@currentType"
                                   asp-route-page="@(currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="History"
                                       asp-route-type="@currentType"
                                       asp-route-page="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="History"
                                   asp-route-type="@currentType"
                                   asp-route-page="@(currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>
