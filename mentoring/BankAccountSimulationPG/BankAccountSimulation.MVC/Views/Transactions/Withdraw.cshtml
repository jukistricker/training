@model BankAccountSimulation.ViewModels.TransactionViewModel

@{
    ViewData["Title"] = "Withdraw Money";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Accounts" asp-action="Details">Account's Details</a></li>
                    <li class="breadcrumb-item active">Withdraw Money</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0 mt-3">
                <div class="card-header bg-warning text-dark py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-box-arrow-right me-2"></i>Withdraw Money
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Withdraw" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small"></div>

                        <div class="mb-3">
                            <label class="form-label text-muted small">Account Number</label>
                            <input asp-for="AccountNumber" class="form-control bg-body-tertiary fw-bold" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label">Amount to withdraw</label>
                            <div class="input-group">
                                <span class="input-group-text bg-warning-subtle text-warning-emphasis">₫</span>
                                <input asp-for="Amount" class="form-control form-control-lg fw-bold" placeholder="0" type="number" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                            <div class="form-text text-muted small mt-2">
                                <i class="bi bi-info-circle me-1"></i> Note: Minium balance after transfering must be 100 VND.
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label">Description (Optional)</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="Withdraw money..."></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning py-2 fw-bold">
                                Withdraw
                            </button>
                            <a asp-controller="Accounts" asp-action="Details" class="btn btn-link text-muted text-decoration-none">Return</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}